@page "/forgot-password"
@inject AuthClientService AuthService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="auth-bg">

    <div class="auth-card">

        <div class="auth-header">
            <div class="logo">⚡ Powerbuilding</div>
            <h1>Reset Password</h1>
            <p>We'll send recovery instructions to your email</p>
        </div>

        <div class="auth-body">

            @if (isSuccess)
            {
                <div class="auth-success" style="text-align: center; padding: 1rem;">
                    <div style="font-size: 2rem; margin-bottom: 1rem;">📩</div>
                    <p style="color: var(--text)">Check your email inbox!</p>
                    <p style="font-size: 0.8rem;">We've sent a recovery link to <b>@email</b></p>

                    <button class="primary-btn" style="width: 100%; margin-top: 1.5rem;" @onclick='() => Nav.NavigateTo("/login")'>
                        Back to Login
                    </button>
                </div>
            }
            else
            {
                <input class="auth-input" type="email" placeholder="Enter your email" @bind="email" @onkeyup="HandleKeyUp" />

                @if (!string.IsNullOrEmpty(msg))
                {
                    <div class="auth-error">@msg</div>
                }

                <button class="auth-btn" @onclick="Send" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <div class="loader-white"></div>
                    }
                    else
                    {
                        <span>Send Reset Link</span>
                    }
                </button>

                <button class="auth-link" @onclick='() => Nav.NavigateTo("/login")'>
                    ← Back to Login
                </button>
            }

        </div>

    </div>

</div>

@code {
    private string email = "";
    private string msg = "";
    private bool isProcessing = false;
    private bool isSuccess = false;

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Send();
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            msg = "Please enter your email address";
            return;
        }

        isProcessing = true;
        msg = "";

        try
        {
            var ok = await AuthService.ForgotPasswordAsync(email);

            if (ok)
            {
                isSuccess = true;
            }
            else
            {
                msg = "Something went wrong. Please try again.";
            }
        }
        catch (Exception)
        {
            msg = "Connection error. Please check your internet.";
        }
        finally
        {
            isProcessing = false;
        }
    }
}