@page "/forgot-password"
@inject AuthClientService AuthService
@inject NavigationManager Nav
@rendermode InteractiveServer
<div class="auth-bg">

    <div class="auth-card">

        <div class="auth-header">
            <h1>Reset Password</h1>
            <p>We will send recovery instructions to your email</p>
        </div>

        <div class="auth-body">

            <input class="auth-input" placeholder="Enter your email" @bind="email" />

            <button class="auth-btn" @onclick="Send">
                Send Reset Link
            </button>

            @if (!string.IsNullOrEmpty(msg))
            {
                <div class="auth-info">@msg</div>
            }

        </div>

    </div>

</div>

@code {
    private string email = "";
    private string msg = "";

    private async Task Send()
    {
        var ok = await AuthService.ForgotPasswordAsync(email);

        msg = ok
            ? "Check your email inbox"
            : "Something went wrong";
    }
}