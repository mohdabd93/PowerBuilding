@page "/Register"
@rendermode InteractiveServer
@inject AuthClientService AuthService
@inject NavigationManager Nav

<div class="wrap">
    <div class="hero" style="padding:2rem 0 1rem;">
        <div class="hero-badge">⚡ Powerbuilding</div>
        <h1>Create <em>Account</em></h1>
    </div>

    @if (invalid)
    {
        <div class="callout c-red">
            Invalid or expired invite link
        </div>
    }
    else
    {
        <div class="prog-card">
            <div style="display:flex; flex-direction:column; gap:0.8rem;">

                <div>
                    <div style="font-size:0.72rem; color:var(--muted2); margin-bottom:0.3rem;">First Name</div>
                    <input placeholder="John" @bind="model.FirstName"
                           style="width:100%; background:var(--s3); border:1px solid var(--border2);
                                          color:var(--text); border-radius:10px; padding:0.6rem 0.8rem; font-size:0.9rem;" />
                </div>

                <div>
                    <div style="font-size:0.72rem; color:var(--muted2); margin-bottom:0.3rem;">Last Name</div>
                    <input placeholder="Doe" @bind="model.LastName"
                           style="width:100%; background:var(--s3); border:1px solid var(--border2);
                                          color:var(--text); border-radius:10px; padding:0.6rem 0.8rem; font-size:0.9rem;" />
                </div>

                <div>
                    <div style="font-size:0.72rem; color:var(--muted2); margin-bottom:0.3rem;">Password</div>
                    <input type="password" placeholder="••••••••" @bind="model.Password"
                           style="width:100%; background:var(--s3); border:1px solid var(--border2);
                                          color:var(--text); border-radius:10px; padding:0.6rem 0.8rem; font-size:0.9rem;" />
                </div>

                @if (!string.IsNullOrEmpty(errorMsg))
                {
                    <div class="callout c-red">❌ @errorMsg</div>
                }

                <button class="tab on" @onclick="SubmitRegister"
                        style="width:100%; padding:0.8rem; font-size:0.9rem;">
                    Create Account
                </button>

            </div>
        </div>
    }
</div>

@code {
    private RegisterRequest model = new();
    private bool invalid = false;
    private string errorMsg = "";

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        model.Token = query["token"] ?? "";

        if (string.IsNullOrEmpty(model.Token))
            invalid = true;
    }

    private async Task SubmitRegister()
    {
        errorMsg = "";
        var ok = await AuthService.RegisterAsync(model);
        if (ok == null)
            Nav.NavigateTo("/login");
        else
            errorMsg = ok; ;
    }
}