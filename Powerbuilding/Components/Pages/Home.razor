
@page "/"
@rendermode InteractiveServer
@inherits AuthenticatedPage

@inject NavigationManager Navigation
@inject WeekPlanClientService WeekPlanService
@inject WorkoutClientService WorkoutService
@inject AuthClientService AuthService
@inject IJSRuntime JS

<PageTitle>Powerbuilding Dashboard</PageTitle>

<div class="dashboard">

    <!-- TOPBAR -->
    <div class="topbar">
        <div class="brand">⚡ Powerbuilding</div>

        <div class="nav-right">
            <button class="icon-btn" @onclick="ToggleTheme">
                @(isDark ? "🌙" : "☀️")
            </button>

            <div class="user" @onclick="ToggleDropdown">
                <div class="avatar">@Initial</div>
                <span class="name">@UserSession.FirstName</span>
            </div>

            @if (showDropdown)
            {
                <div class="dropdown">

                    <div class="dropdown-header">
                        <div class="big-avatar">@Initial</div>
                        <div>
                              <div class="d-email">@UserSession.Email</div>
                            <div class="d-name">@UserSession.FirstName @UserSession.LastName</div>
                        </div>
                    </div>

                    <div class="divider"></div>

                    <!-- PROFILE -->
                    <button class="drop-item" @onclick="GoToProfile">
                        👤 Profile
                    </button>

                    <!-- SETTINGS -->
                    <button class="drop-item" @onclick="GoToSettings">
                        ⚙️ Settings
                    </button>

                    <div class="divider"></div>

                    <!-- LOGOUT -->
                    <button class="drop-item logout" @onclick="Logout">
                        🚪 Logout
                    </button>

                </div>
            }
        </div>
    </div>

    <!-- HERO -->
    <div class="hero">
        <div class="hero-badge">⚡ Dashboard</div>
        <h1>Train. Track. Progress.</h1>
        <p class="hero-sub">Everything you need in one place.</p>
    </div>

    <!-- QUICK STATS -->
    <div class="stats">
        <div class="stat">
            <div class="stat-val">@days?.Count ?? 0</div>
            <div class="stat-label">Workout Days</div>
        </div>

        <div class="stat">
            <div class="stat-val">@meals?.Count ?? 0</div>
            <div class="stat-label">Meals</div>
        </div>

        <div class="stat">
            <div class="stat-val">@supplements?.Count ?? 0</div>
            <div class="stat-label">Supplements</div>
        </div>
    </div>

    <!-- MAIN CARDS -->
    <div class="grid">

        <div class="card" @onclick='() => Navigation.NavigateTo("/workouts")'>
            <div class="card-title">🏋️ Training</div>
            <div class="card-desc">Manage your workout plan</div>
        </div>

        <div class="card" @onclick='() => Navigation.NavigateTo("/nutrition")'>
            <div class="card-title">🍽️ Nutrition</div>
            <div class="card-desc">Meal structure & macros</div>
        </div>

        <div class="card" @onclick='() => Navigation.NavigateTo("/supplements")'>
            <div class="card-title">💊 Supplements</div>
            <div class="card-desc">Stack & timing</div>
        </div>

        <div class="card" @onclick='() => Navigation.NavigateTo("/progress")'>
            <div class="card-title">📈 Progress</div>
            <div class="card-desc">Track improvements</div>
        </div>

    </div>

</div>

@code {

    private List<WorkoutDay>? days;
    private List<Meal>? meals;
    private List<Supplement>? supplements;

    private bool showDropdown;
    private bool isDark;

    private string Initial => UserSession.UserName?.FirstOrDefault().ToString() ?? "?";

    protected override async Task OnPageLoadAsync()
    {
        var week = await WeekPlanService.GetFullWeekPlanAsync();
        days = week?.Days;
        meals = week?.Meals;
        supplements = week?.Supplements;
    }

    private void ToggleDropdown()
        => showDropdown = !showDropdown;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private void ToggleTheme()
    {
        isDark = !isDark;
        JS.InvokeVoidAsync("document.body.setAttribute", "data-theme", isDark ? "dark" : "light");
    }
    private void GoToProfile()
    {
        showDropdown = false;
        Navigation.NavigateTo("/profile");
    }

    private void GoToSettings()
    {
        showDropdown = false;
        Navigation.NavigateTo("/settings");
    }
}