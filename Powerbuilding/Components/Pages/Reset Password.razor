@page "/Reset-password"
@inject AuthClientService AuthService
@inject NavigationManager Nav
@rendermode InteractiveServer
<div class="auth-wrapper">

    <div class="auth-container">

        <!-- Header -->
        <div class="auth-header">
            <div class="icon">🔒</div>
            <h1>Reset Password</h1>
            <p>Create a new secure password for your account</p>
        </div>

        <!-- Form -->
        <div class="auth-form">

            <div class="input-group">
                <label>New Password</label>
                <input type="password"
                       placeholder="••••••••"
                       @bind="model.NewPassword" />
            </div>

            <div class="input-group">
                <label>Confirm Password</label>
                <input type="password"
                       placeholder="••••••••"
                       @bind="confirmPassword" />
            </div>

            <button class="auth-btn" @onclick="Reset">
                Reset Password
            </button>

            @if (!string.IsNullOrEmpty(msg))
            {
                <div class="auth-message">@msg</div>
            }

        </div>

        <!-- Footer -->
        <div class="auth-footer">
            <a href="/login">Back to Login</a>
        </div>

    </div>

</div>

@code {

    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private string confirmPassword = "";
    private string msg = "";
    private ResetPasswordRequest model = new();

    private async Task Reset()
    {
        msg = "";

        if (string.IsNullOrWhiteSpace(model.NewPassword))
        {
            msg = "Password is required";
            return;
        }

        if (model.NewPassword != confirmPassword)
        {
            msg = "Passwords do not match";
            return;
        }

        var request = new ResetPasswordRequest
        {
            Email = Email,
            Token = Token,
            NewPassword = model.NewPassword
        };

        var res = await AuthService.ResetPasswordAsync(request);

        if (res.Success)
        {
            Nav.NavigateTo("/login", forceLoad: true);
        }
        else
        {
        //    msg = "Reset failed. Try again.";
            msg = res.Error?.Replace(",", "\n") ?? "Reset failed";
        }
    }
}