@page "/Reset-password"
@inject AuthClientService AuthService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="auth-bg">

    <div class="auth-card">

        <div class="auth-header">
            <div class="logo">⚡ Powerbuilding</div>
            <h1>Reset Password</h1>
            <p>Create a new secure password for your account</p>
        </div>

        <div class="auth-body">

            @if (isSuccess)
            {
                <div class="auth-success" style="text-align: center;">
                    <div style="font-size: 2.5rem; margin-bottom: 1rem;">✅</div>
                    <h3>Password Updated!</h3>
                    <p>Your password has been changed successfully.</p>
                    <button class="primary-btn" style="width: 100%; margin-top: 1.5rem;" @onclick='() => Nav.NavigateTo("/login")'>
                        Go to Login
                    </button>
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <label style="font-size: 0.8rem; color: var(--muted); margin-left: 0.5rem;">New Password</label>
                    <input class="auth-input" type="password" placeholder="••••••••" @bind="model.NewPassword" />
                </div>

                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <label style="font-size: 0.8rem; color: var(--muted); margin-left: 0.5rem;">Confirm New Password</label>
                    <input class="auth-input" type="password" placeholder="••••••••" @bind="confirmPassword" @onkeyup="HandleKeyUp" />
                </div>

                @if (!string.IsNullOrEmpty(msg))
                {
                    <div class="auth-error">@msg</div>
                }

                <button class="auth-btn" @onclick="Reset" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <div class="loader-white"></div>
                    }
                    else
                    {
                        <span>Update Password</span>
                    }
                </button>

                <button class="auth-link" @onclick='() => Nav.NavigateTo("/login")'>
                    ← Back to Login
                </button>
            }

        </div>

    </div>

</div>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private string confirmPassword = "";
    private string msg = "";
    private bool isProcessing = false;
    private bool isSuccess = false;
    private ResetPasswordRequest model = new();

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Reset();
    }

    private async Task Reset()
    {
        if (isProcessing) return;

        msg = "";
         
        if (string.IsNullOrWhiteSpace(model.NewPassword))
        {
            msg = "Password is required";
            return;
        }

        if (model.NewPassword != confirmPassword)
        {
            msg = "Passwords do not match";
            return;
        }

        if (string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Token))
        {
            msg = "Invalid reset link. Please request a new one.";
            return;
        }

        isProcessing = true;

        try
        {
            var request = new ResetPasswordRequest
            {
                Email = Email,
                Token = Token,
                NewPassword = model.NewPassword
            };

            var res = await AuthService.ResetPasswordAsync(request);

            if (res.Success)
            {
                isSuccess = true;
                StateHasChanged();
            }
            else
            { 
                msg = res.Error?.Replace(",", "\n") ?? "Reset failed";
            }
        }
        catch (Exception)
        {
            msg = "Connection error. Please try again later.";
        }
        finally
        {
            isProcessing = false;
        }
    }
}